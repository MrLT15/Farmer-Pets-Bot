# Required Discord and database settings
DISCORD_TOKEN=replace-with-your-discord-bot-token
CLIENT_ID=replace-with-your-discord-application-client-id
GUILD_ID=replace-with-your-discord-server-id
DATABASE_URL=postgres://user:password@host:5432/database

# Discord channel IDs. The bot ships with Farmer Pets defaults, but deployments
# should set these explicitly for the target Discord server.
FARM_CHANNEL_ID=replace-with-farm-event-channel-id
LEADERBOARD_CHANNEL_ID=replace-with-leaderboard-channel-id

# Discord role IDs. The bot ships with Farmer Pets defaults, but deployments
# should set these explicitly if role IDs differ in the target Discord server.
FARMER_VERIFIED_ROLE_ID=replace-with-verified-role-id
FARMER_FOOD_ROLE_ID=replace-with-food-role-id
FARMER_WOOD_ROLE_ID=replace-with-wood-role-id
FARMER_SILVER_ROLE_ID=replace-with-silver-role-id
FARMER_TOOL_ROLE_ID=replace-with-tool-role-id
FARMER_WORKING_FARM_ROLE_ID=replace-with-working-farm-role-id
FARMER_FULL_FARM_ROLE_ID=replace-with-full-farm-role-id

# Optional health server port for hosts that expect an HTTP listener.
# PORT is also supported and is commonly provided by platforms like Render.
# In dashboards like Render, use key HEALTH_PORT with value 3000.
HEALTH_PORT=3000

# Optional: set to false if the bot can post farm events but cannot create
# public threads in the farm event channel.
ENABLE_EVENT_THREADS=true

# Optional API overrides. Leave these unset unless the upstream service changes.
ATOMIC_API=https://wax.api.atomicassets.io/atomicassets/v1/assets
FARMER_PETS_API=https://pets-api-main.herokuapp.com
CONTRACT_ACCOUNT=farmerpetssc
